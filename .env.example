# ── Convex (generado por `npx convex dev`) ──────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ── OpenRouter (IA) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Modelo para generación de ideas editoriales — por defecto: google/gemini-2.0-flash-lite
# Alternativas económicas: google/gemini-2.0-flash-001, meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=google/gemini-2.0-flash-lite
# La misma OPENROUTER_API_KEY se usa para búsqueda de Fechas Especiales
# El modelo de búsqueda es perplexity/sonar-pro (hardcoded en lib/specialDates.ts)
# Requiere saldo en OpenRouter — aprox. $5 MXN por búsqueda de mes completo

# ── Tumblr ───────────────────────────────────────────────────────────────────
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
TUMBLR_OAUTH_TOKEN=
TUMBLR_OAUTH_TOKEN_SECRET=
TUMBLR_BLOG_NAME=

# ── X / Twitter ──────────────────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Convex Auth (configurar en Convex Dashboard, no en .env.local) ───────────
# JWT_PRIVATE_KEY=  (se genera con: npx @convex-dev/auth generate-keys)
# SITE_URL=         (URL pública de la app, ej: https://tu-proyecto.vercel.app)
